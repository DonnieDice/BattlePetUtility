<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
	<CheckButton name="BattlePetUtilityAutoHealButton" frameStrata="MEDIUM" inherits="UICheckButtonTemplate" parent="GossipFrame" hidden="true">
		<Anchors>
			<Anchor point="TOPRIGHT" relativeTo="GossipFrame" relativePoint="TOPRIGHT" x="-80" y="-27"/>
		</Anchors>
		<Scripts>
			<OnShow>
				AutoHealButton_OnShow(self);
				self.text:SetText("Auto Heal Pets")
				self:SetFrameLevel(GossipFrame:GetFrameLevel()+2);
			</OnShow>
			<OnClick>
				AutoHealButton_OnClick(self)
			</OnClick>
		</Scripts>
	</CheckButton>
	
	<Button name="BattlePetUtilityFrame" parent="UIParent" frameStrata="MEDIUM" movable="true" toplevel="true" clampedToScreen="true">
		<Size x="208" y="208"/>
		<Anchors>
			<Anchor point="CENTER" x="0" y="0"/>
		</Anchors>
		<Frames>
			<Frame name="$parentTitle" inherits="BackdropTemplate" enableMouse="true">
				<Size>
					<AbsDimension x="208" y="24"/>
				</Size>
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent" x="0" y="0" />
				</Anchors>
				<Layers>
					<Layer level="ARTWORK" textureSubLevel="2">
						<Texture name="$parentLogo" parentKey="logo" file="Interface\AddOns\BattlePetUtility\media\logo.tga">
							<Size x="20" y="20"/>
							<Anchors>
								<Anchor point="LEFT" x="4" y="0"/>
							</Anchors>
						</Texture>
					</Layer>
					<Layer level="ARTWORK" textureSubLevel="1">
						<FontString name="$parentTitleText" inherits="BattlePetUtilityFontNormal" justifyH="LEFT" justifyV="CENTER" parentKey="titleText" text="|cffb512fcB|r|cffffffffattle |cffb512fcP|r|cffffffffet |cffb512fcU|r|cfffffffftility|r|cffb512fc!|r">
							<Size x="136" y="20"/>
							<Anchors>
								<Anchor point="LEFT" relativeTo="$parent" x="28" y="0"/>
							</Anchors>
						</FontString>
					</Layer>
				</Layers>
				<Scripts>
					<OnLoad>
						if(self.SetBackdrop) then
							self:SetBackdrop({
								bgFile = "Interface\\Tooltips\\UI-Tooltip-Background",
								edgeFile = "Interface\\Tooltips\\UI-Tooltip-Border",
								tile = true,
								tileSize = 16,
								edgeSize = 10,
								insets = { left = 3, right = 3, top = 3, bottom = 3 },
							});
						end
						if(self.SetBackdropColor) then
							self:SetBackdropColor(0.02, 0.02, 0.035, 0.78);
						end
						if(self.SetBackdropBorderColor) then
							self:SetBackdropBorderColor(0.45, 0.18, 0.85, 0.95);
						end
					</OnLoad>
					<OnMouseDown>
						BattlePetUtilityFrameTitle_OnMouseDown(self, button);
					</OnMouseDown>
					<OnMouseUp>
						BattlePetUtilityFrameTitle_OnMouseUp(self, button);
					</OnMouseUp>
				</Scripts>
				<Frames>
					<Button parentKey="closeButton" frameLevel="9">
						<Size x="14" y="14"/>
						<Anchors>
							<Anchor point="RIGHT" relativeTo="$parent" x="-6" y="0"/>
						</Anchors>
						<Layers>
							<Layer level="OVERLAY">
								<FontString parentKey="label" inherits="BattlePetUtilityFontNormal" justifyH="CENTER" justifyV="MIDDLE" text="x">
									<Anchors>
										<Anchor point="CENTER" x="0" y="0"/>
									</Anchors>
									<Color r="0.96" g="0.87" b="1.0"/>
								</FontString>
							</Layer>
						</Layers>
						<Scripts>
							<OnLoad>
								BattlePetUtilityHeaderButton_OnLoad(self, "close");
							</OnLoad>
							<OnClick>
								BattlePetUtilityHeaderButton_OnClick(self, button);
							</OnClick>
							<OnEnter>
								BattlePetUtilityHeaderButton_OnEnter(self);
							</OnEnter>
							<OnLeave>
								BattlePetUtilityHeaderButton_OnLeave(self);
							</OnLeave>
						</Scripts>
					</Button>
					<Button parentKey="minimizeButton" frameLevel="9">
						<Size x="14" y="14"/>
						<Anchors>
							<Anchor point="RIGHT" relativeKey="$parent.closeButton" relativePoint="LEFT" x="-3" y="0"/>
						</Anchors>
						<Layers>
							<Layer level="OVERLAY">
								<FontString parentKey="label" inherits="BattlePetUtilityFontNormal" justifyH="CENTER" justifyV="MIDDLE" text="-">
									<Anchors>
										<Anchor point="CENTER" x="0" y="0"/>
									</Anchors>
									<Color r="0.95" g="0.90" b="1.0"/>
								</FontString>
							</Layer>
						</Layers>
						<Scripts>
							<OnLoad>
								BattlePetUtilityHeaderButton_OnLoad(self, "minimize");
							</OnLoad>
							<OnClick>
								BattlePetUtilityHeaderButton_OnClick(self, button);
							</OnClick>
							<OnEnter>
								BattlePetUtilityHeaderButton_OnEnter(self);
							</OnEnter>
							<OnLeave>
								BattlePetUtilityHeaderButton_OnLeave(self);
							</OnLeave>
						</Scripts>
					</Button>
					<PlayerModel name="$parentPepeFrame" parentKey="pepeFrame">
						<Size x="50" y="50"/>
						<Scripts>
							<OnLoad>
								self:EnableMouse(false);
								self:SetFrameStrata("DIALOG");
								self:SetFrameLevel(self:GetParent():GetFrameLevel() + 12);
								self:SetCreature(86470);
								self:SetPosition(-0.15, 0, 0);
								self:SetRotation(-0.2);
							</OnLoad>
						</Scripts>
					</PlayerModel>
					<Frame name="$parentPetCharms" mixin="BattlePetUtility_PetCharmsMixin">
						<Size x="46" y="20"/>
						<Anchors>
							<Anchor point="RIGHT" relativeKey="$parent.minimizeButton" relativePoint="LEFT" x="-4" y="0"/>
						</Anchors>
						<Layers>
							<Layer level="ARTWORK">
								<Texture parentKey="icon">
									<Size x="14" y="14"/>
									<Anchors>
										<Anchor point="RIGHT"/>
									</Anchors>
									<TexCoords left="0.055" right="0.945" top="0.055" bottom="0.945"/>
								</Texture>
								<FontString name="$parentText" inherits="BattlePetUtilityFontNormal" justifyH="RIGHT" justifyV="CENTER" parentKey="text">
									<Size x="46" y="20"/>
									<Anchors>
										<Anchor point="RIGHT" x="-16" y="0"/>
									</Anchors>
								</FontString>
							</Layer>
						</Layers>
						<Scripts>
							<OnShow method="OnShow"/>
							<OnHide method="OnHide"/>
							<OnEvent method="OnEvent"/>
							<OnEnter method="OnEnter"/>
							<OnLeave method="OnLeave"/>
						</Scripts>
					</Frame>
				</Frames>
			</Frame>
			
			<Button name="$parentPet1" parentKey="pet1" inherits="BattlePetUtilityPetFrameTemplate" id="1">
				<Anchors>
					<Anchor point="TOP" relativeTo="$parent" x="0" y="-24"/>
				</Anchors>
			</Button>
			<Button name="$parentPet2" parentKey="pet2" inherits="BattlePetUtilityPetFrameTemplate" id="2">
				<Anchors>
					<Anchor point="TOP" relativeTo="$parentPet1" relativePoint="BOTTOM" x="0" y="-3"/>
				</Anchors>
			</Button>
			<Button name="$parentPet3" parentKey="pet3" inherits="BattlePetUtilityPetFrameTemplate" id="3">
				<Anchors>
					<Anchor point="TOP" relativeTo="$parentPet2" relativePoint="BOTTOM" x="0" y="-3"/>
				</Anchors>
			</Button>
			<Frame name="$parentZoneTracker" parentKey="zoneTracker" mixin="BattlePetUtility_ZoneTrackerMixin" hidden="true" enableMouse="true">
				<Size x="208" y="30"/>
				<Layers>
					<Layer level="OVERLAY">
						<FontString name="$parentLabel" parentKey="label" inherits="BattlePetUtilityFontSmall" justifyH="LEFT" justifyV="CENTER" text="Zone Pets">
							<Size x="128" y="12"/>
							<Anchors>
								<Anchor point="TOPLEFT" x="8" y="-5"/>
							</Anchors>
							<Color r="0.94" g="0.90" b="1.0"/>
						</FontString>
						<FontString name="$parentValue" parentKey="value" inherits="BattlePetUtilityFontSmall" justifyH="RIGHT" justifyV="CENTER">
							<Size x="52" y="12"/>
							<Anchors>
								<Anchor point="TOPRIGHT" x="-8" y="-5"/>
							</Anchors>
							<Color r="0.94" g="0.90" b="1.0"/>
						</FontString>
						<FontString name="$parentHint" parentKey="hint" inherits="BattlePetUtilityFontSmall" justifyH="LEFT" justifyV="CENTER" hidden="true">
							<Size x="182" y="12"/>
							<Anchors>
								<Anchor point="BOTTOMLEFT" x="8" y="4"/>
							</Anchors>
							<Color r="0.84" g="0.84" b="0.90"/>
						</FontString>
						<FontString name="$parentPetsText" parentKey="petsText" inherits="BattlePetUtilityFontSmall" justifyH="LEFT" justifyV="CENTER" hidden="true">
							<Size x="182" y="12"/>
							<Anchors>
								<Anchor point="BOTTOMLEFT" x="8" y="4"/>
							</Anchors>
							<Color r="0.90" g="0.90" b="0.96"/>
						</FontString>
					</Layer>
				</Layers>
				<Frames>
					<StatusBar name="$parentBar" parentKey="bar">
						<Size x="192" y="9"/>
						<Anchors>
							<Anchor point="TOPLEFT" relativeKey="$parent.label" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
							<Anchor point="TOPRIGHT" relativeKey="$parent.value" relativePoint="BOTTOMRIGHT" x="0" y="-2"/>
						</Anchors>
						<BarTexture file="Interface\TargetingFrame\UI-StatusBar" parentKey="texture"/>
						<Layers>
							<Layer level="BACKGROUND">
								<Texture parentKey="bg" setAllPoints="true">
									<Color r="0.12" g="0.12" b="0.18" a="0.9"/>
								</Texture>
							</Layer>
							<Layer level="OVERLAY">
								<FontString name="$parentText" parentKey="text" inherits="BattlePetUtilityFontSmall" justifyH="CENTER" justifyV="CENTER">
									<Anchors>
										<Anchor point="CENTER"/>
									</Anchors>
									<Color r="1.0" g="1.0" b="1.0"/>
								</FontString>
							</Layer>
						</Layers>
					</StatusBar>
				</Frames>
				<Scripts>
					<OnEnter method="OnEnter"/>
					<OnLeave method="OnLeave"/>
					<OnMouseUp method="OnMouseUp"/>
				</Scripts>
			</Frame>

			<Frame name="$parentSpellSelect" frameStrata="DIALOG" parentKey="spellSelect" hidden="true">
				<Size x="28" y="69"/>	
				<Layers>
					<Layer level="BACKGROUND">
						<Texture parentKey="BgEnd" file="Interface\Buttons\ActionBarFlyoutButton">
							<Size x="37" y="22"/>	
							<Anchors>
								<Anchor point="BOTTOM"/>
							</Anchors>
							<TexCoords left="0.01562500" right="0.59375000" top="0.91406250" bottom="0.74218750"/>	
						</Texture>
						<Texture parentKey="BgTiled" file="Interface\Buttons\ActionBarFlyoutButton-FlyoutMid" vertTile="true">
							<Size x="37" y="32"/>
							<Anchors>
								<Anchor point="TOP" relativeKey="$parent" relativePoint="TOP" x="0" y="0"/>
								<Anchor point="BOTTOM" relativeKey="$parent.BgEnd" relativePoint="TOP" x="0" y="0"/>
							</Anchors>
							<TexCoords left="0" right="0.578125" top="0" bottom="1"/>
						</Texture>
					</Layer>
				</Layers>
				<Frames>
					<CheckButton name="$parentSpell1" inherits="PetSpellSelectButtonTemplate" id="1" parentKey="Spell1">
						<Anchors>
							<Anchor point="TOP" relativeKey="$parent" relativePoint="TOP" x="0" y="-5"/>
						</Anchors>
					</CheckButton>
					<CheckButton name="$parentSpell2" inherits="PetSpellSelectButtonTemplate" id="2" parentKey="Spell2">
						<Anchors>
							<Anchor point="TOP" relativeKey="$parent.Spell1" relativePoint="BOTTOM" x="0" y="-4"/>
						</Anchors>
					</CheckButton>
 				</Frames>
				<Scripts>
					<OnShow>
						self:SetFrameLevel(self:GetFrameLevel() + 5);
					</OnShow>
					<OnHide>
						PetJournalPrimaryAbilityTooltip:Hide();
						PetJournalSecondaryAbilityTooltip:Hide();
					</OnHide>
				</Scripts>
			</Frame>
			
			<Frame name="$parentButtons" parentKey="buttons">
				<Size x="208" y="36"/>
				<Anchors>
					<Anchor point="TOPRIGHT" relativeTo="$parentPet3" relativePoint="BOTTOMRIGHT"/>
				</Anchors>
				<Frames>
					<CheckButton name="$parentItemButton1" parentKey="itemButton1" inherits="BattlePetUtilityButtonTemplate" hidden="true">
						<Anchors>
							<Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT" x="6" y="-6"/>
						</Anchors>
					</CheckButton>
					<CheckButton name="$parentItemButton2" parentKey="itemButton2" inherits="BattlePetUtilityButtonTemplate" hidden="true">
						<Anchors>
							<Anchor point="LEFT" relativeKey="$parent.itemButton1" relativePoint="RIGHT" x="6" y="0"/>
						</Anchors>
					</CheckButton>
					<CheckButton name="$parentItemButton3" parentKey="itemButton3" inherits="BattlePetUtilityButtonTemplate" hidden="true">
						<Anchors>
							<Anchor point="LEFT" relativeKey="$parent.itemButton2" relativePoint="RIGHT" x="6" y="0"/>
						</Anchors>
					</CheckButton>
					<CheckButton name="$parentItemButton4" parentKey="itemButton4" inherits="BattlePetUtilityButtonTemplate" hidden="true">
						<Anchors>
							<Anchor point="LEFT" relativeKey="$parent.itemButton3" relativePoint="RIGHT" x="6" y="0"/>
						</Anchors>
					</CheckButton>
					<CheckButton name="$parentItemButton5" parentKey="itemButton5" inherits="BattlePetUtilityButtonTemplate" hidden="true">
						<Anchors>
							<Anchor point="LEFT" relativeKey="$parent.itemButton4" relativePoint="RIGHT" x="6" y="0"/>
						</Anchors>
					</CheckButton>
					<CheckButton name="$parentItemButton6" parentKey="itemButton6" inherits="BattlePetUtilityButtonTemplate" hidden="true">
						<Anchors>
							<Anchor point="LEFT" relativeKey="$parent.itemButton5" relativePoint="RIGHT" x="6" y="0"/>
						</Anchors>
					</CheckButton>
					
					<Frame name="BattlePetUtilityFlyout" inherits="BattlePetUtilityFlyoutTemplate" hidden="true">
						<Size x="36" y="720"/>
						<Anchors>
							<Anchor point="TOP" relativePoint="BOTTOM" />
						</Anchors>
						<Scripts>
							<OnLoad>
								tinsert(UISpecialFrames, self:GetName());
							</OnLoad>
						</Scripts>
					</Frame>
				</Frames>
				<Scripts>
					<OnLoad>
						self:SetScale(0.6);
					</OnLoad>
					<OnShow>
						BattlePetUtilityFrameButtons_OnShow(self);
					</OnShow>
					<OnHide>
						BattlePetUtilityFrameButtons_OnHide(self);
					</OnHide>
					<OnEvent>
						BattlePetUtilityFrameButtons_OnEvent(self, event, ...);
					</OnEvent>
				</Scripts>
			</Frame>
			<Frame name="$parentLoadouts" parentKey="loadouts" hidden="true">
				<Size x="208" y="36"/>
				<Anchors>
					<Anchor point="TOPRIGHT" relativeTo="$parentPet3" relativePoint="BOTTOMRIGHT"/>
				</Anchors>
				<Frames>
					<CheckButton name="$parentToggleButton" parentKey="toggleButton" inherits="BattlePetUtilityButtonTemplate">
						<Size x="36" y="36"/>
						<Anchors>
							<Anchor point="TOPRIGHT" relativePoint="TOPRIGHT" x="-10" y="-6"/>
						</Anchors>
						<Scripts>
							<OnLoad>
								self:SetScale(0.6);
								BattlePetUtilityLoadoutsToggleButton_OnLoad(self);
							</OnLoad>
						</Scripts>
					</CheckButton>
					<CheckButton name="$parentSaveButton" parentKey="saveButton" inherits="BattlePetUtilityButtonTemplate">
						<Size x="36" y="36"/>
						<Anchors>
							<Anchor point="RIGHT" relativeKey="$parent.toggleButton" relativePoint="LEFT" x="-8" y="0"/>
						</Anchors>
						<Scripts>
							<OnLoad>
								self:SetScale(0.6);
								BattlePetUtilityLoadoutsSaveButton_OnLoad(self);
							</OnLoad>
						</Scripts>
					</CheckButton>
					
					<ScrollFrame name="$parentScrollFrame" parentKey="scrollFrame" inherits="HybridScrollFrameTemplate" frameStrata="HIGH" hidden="true">
						<Size x="208" y="138"/>
						<Anchors>
							<Anchor point="TOP" relativeTo="$parent" x="0" y="-31"/>
						</Anchors>
						<Frames>
							<Slider name="$parentScrollBar" inherits="BattlePetUtilityLoadoutsScrollBarTemplate" parentKey="scrollBar" hidden="true">
								<Anchors>
									<Anchor point="TOPLEFT" relativePoint="TOPRIGHT" x="-4" y="6"/>
									<Anchor point="BOTTOMLEFT" relativePoint="BOTTOMRIGHT" x="-4" y="-6"/>
								</Anchors>
							</Slider>
						</Frames>
						<Scripts>
							<OnLoad>
								tinsert(UISpecialFrames, self:GetName());
								self:SetFrameLevel((self:GetFrameLevel() or 0) + 20);
							</OnLoad>
							<OnHide>
								BattlePetUtilityFrameLoadoutsScrollFrame_ToggleVisibility(false);
							</OnHide>
						</Scripts>
					</ScrollFrame>
				</Frames>
				<Scripts>
					<OnLoad>
						BattlePetUtilityFrameLoadouts_OnLoad(self);
					</OnLoad>
				</Scripts>
			</Frame>
		</Frames>
		<Scripts>
			<OnLoad>
				self:EnableMouseWheel(true);
				self:RegisterForClicks("RightButtonUp");
			</OnLoad>
			<OnClick>
				BattlePetUtilityFrame_OnClick(self, button);
			</OnClick>
			<OnMouseWheel>
				BattlePetUtilityFrame_OnMouseWheel(self, delta);
			</OnMouseWheel>
			<OnMouseDown>
				BattlePetUtilityFrame_StartMoving(button);
			</OnMouseDown>
			<OnMouseUp>
				BattlePetUtilityFrame_StopMoving(button);
			</OnMouseUp>
			<OnShow>
				BattlePetUtilityFrame_OnShow(self);
			</OnShow>
			<OnHide>
				BattlePetUtilityFrame_OnHide(self);
			</OnHide>
		</Scripts>
	</Button>
</Ui>
